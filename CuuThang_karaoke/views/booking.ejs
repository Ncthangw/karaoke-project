<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Booking List</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        rel="stylesheet">
</head>

<body class="container mt-5">

    <h1 class="mb-4">
        Booking List
    </h1>

    <a
        href="/bookings/add"
        class="btn btn-success mb-3">

        Add New Booking

    </a>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>
                <th>Customer</th>
                <th>Room Number</th>
                <th>Start Time</th>
                <th>End Time</th>
                <th>Total Amount</th>
                <th>Action</th>
            </tr>

        </thead>

        <tbody>

        <% bookings.forEach(booking => { %>

            <tr>

                <td>
                    <%= booking.customerName %>
                </td>

                <td>
                    <%= booking.roomNumber %>
                </td>

                <td>
                    <%= booking.startTime.toLocaleString() %>
                </td>

                <td>
                    <%= booking.endTime.toLocaleString() %>
                </td>

                <td>
                    $<%= booking.totalAmount %>
                </td>

                <td>

                    <a
                        href="/bookings/edit/<%= booking._id %>"
                        class="btn btn-warning btn-sm">

                        Edit

                    </a>

                    <a
                        href="/bookings/delete/<%= booking._id %>"
                        class="btn btn-danger btn-sm">

                        Delete

                    </a>

                </td>

            </tr>

        <% }) %>

        </tbody>

    </table>

</body>
</html>